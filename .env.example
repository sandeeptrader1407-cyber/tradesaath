# ─────────────────────────────────────────────────────────────
# TradeSaath — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=

# Google (Gemini AI)
GEMINI_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Razorpay Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# Resend Email
RESEND_API_KEY=

# Cloudflare R2 Storage
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Feature flags (Module 2 rollout)
# ─────────────────────────────────────────────────────────────
# Turn Module 2 compute pipeline on for all users. Default off.
# NEXT_PUBLIC_USE_MODULE_2=false
#
# Shadow mode — run Module 2 alongside the legacy path, but SERVE
# the legacy result. One-line diffs logged as [MODULE_2_SHADOW].
# Takes precedence over NEXT_PUBLIC_USE_MODULE_2 (safe default).
# MODULE_2_SHADOW_MODE=false
